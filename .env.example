# Server
PORT=4000
CLIENT_URL=http://localhost:5173

# Optional production persistence through Supabase PostgreSQL.
# Keep this only on the backend hosting service. Never put it in the React client.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
PGSSLMODE=require

# Client optional direct API base. Usually not needed if using Vercel rewrites.
VITE_API_BASE_URL=/api

# Phase 3 authentication
AUTH_REQUIRED=true
SUPABASE_ANON_KEY=your_supabase_publishable_key

# Vercel frontend variables
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Phase 6 optional email notifications through SMTP.
# Put these only in Render backend environment variables.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="Team Outing Expense Tracker <your-email@gmail.com>"
